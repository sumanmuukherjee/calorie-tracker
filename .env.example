# Copy to .env and fill in from your Supabase project
# (Supabase Dashboard → Project Settings → API).
# Leave these unset to run the app in local mode (localStorage, no login).

VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Optional: USDA FoodData Central API key for food search.
# Free instant signup at https://fdc.nal.usda.gov/api-key-signup (1,000 req/hour).
# Falls back to the shared DEMO_KEY (~30 req/hour) if unset.
VITE_USDA_API_KEY=DEMO_KEY
